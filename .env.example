DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/bfs
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/bfs
SECRET_KEY=change-me-to-a-long-random-string
# Optional: overrides default 7 days in code (minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
#
# .env у корені репо. Запуск: make run.
#
# Якщо колись запускатимеш pytest з *хоста* (не з контейнера), а Postgres лише в Docker з портом 5433:
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/bfs_test
# TEST_DATABASE_URL_SYNC=postgresql://postgres:postgres@127.0.0.1:5433/bfs_test